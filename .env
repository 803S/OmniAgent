# OmniAgent 运行时环境变量配置
# 后端启动时默认读取这份文件。

# ============================================================================
# 模型配置
# ============================================================================
# 可选值: ccswitch / deepseek / openai / anthropic / internal / local
# 可留空让后端按当前已填写的 API 环境变量自动推断 provider。
# MODEL_PROVIDER=internal

# ----- 当前生效 API 配置：只保留这一组 -----
# 通用规则：
# 1. 只保留一套 active 配置，其他 provider 全部注释。
# 2. 公司网关 / 中转站如果是 Anthropic 兼容，就填 anthropic。
# 3. 如果是 OpenAI 兼容，就改成 openai_compatible，并填写 INTERNAL_API_KEY。

# 也兼容直接照抄对方文档里的环境变量。
# 例如很多 Claude / Anthropic 兼容网关会给出下面这种写法：

# 例如 OpenAI 兼容中转站常见写法：
# OPENAI_BASE_URL=https://your-gateway.example/v1
# OPENAI_API_KEY=your-key
# OPENAI_MODEL=gpt-4o-mini
#
# 上面两种写法即使不改成 INTERNAL_*，在 MODEL_PROVIDER=internal 时也会自动兼容。

# ----- 其他 provider 示例：默认全部注释，避免混配 -----
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
#
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_REASONING_MODEL=
# ANTHROPIC_BASE_URL=
#
# LOCAL_MODEL_URL=http://localhost:11434
# LOCAL_MODEL_NAME=llama3
#
# CCSWITCH_BASE_URL=
# CCSWITCH_API_KEY=
# CCSWITCH_MODEL=auto
# CCSWITCH_PROXY_HOST=127.0.0.1
# CCSWITCH_PROXY_PORT=15721
# CCSWITCH_PROXY_URL=
# CCSWITCH_TRUST_SYSTEM_PROXY=0
# CCSWITCH_USE_HTTP_PROXY=0

# ----- 系统代理 -----
# 若公司机器存在显式系统代理，开启后会自动尝试跟随系统代理。
OMNIAGENT_TRUST_SYSTEM_PROXY=1

# ============================================================================
# 服务配置
# ============================================================================
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# ============================================================================
# 功能开关
# ============================================================================
BROWSER_ENABLED=true
RAG_ENABLED=true
