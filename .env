# OmniAgent 环境变量配置

# ============================================================================
# API 安全（必填，用于本地 API 鉴权）
# ============================================================================
API_TOKEN=your-secure-token-here

# ============================================================================
# 模型配置
# ============================================================================
# 可选值: deepseek / anthropic / openai / gemini / xiaomi / internal / local
MODEL_PROVIDER=deepseek

# ----- DeepSeek -----
DEEPSEEK_API_KEY=sk-98eba6cea54743658a78aede1cc191a7
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ----- OpenAI (GPT-4, GPT-3.5) -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# ----- Google Gemini -----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ----- 小米大模型 -----
XIAOMI_API_KEY=
XIAOMI_MODEL=mi-abab6.5-chat
XIAOMI_BASE_URL=https://api.xiaomi.com/v1

# ----- 公司内部模型（OpenAI 兼容） -----
INTERNAL_API_KEY=
INTERNAL_MODEL=your-model
INTERNAL_BASE_URL=http://your-internal-api:8000/v1

# ----- 本地模型（Ollama/vLLM） -----
LOCAL_MODEL_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3

# ============================================================================
# 服务配置
# ============================================================================
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# ============================================================================
# 功能开关
# ============================================================================
BROWSER_ENABLED=true
RAG_ENABLED=true